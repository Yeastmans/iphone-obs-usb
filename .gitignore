# ── Xcode (generated by XcodeGen at build time) ─────────────────────────────
ios/CameraStream.xcodeproj/
ios/build/
*.xcworkspace
xcuserdata/
DerivedData/
*.ipa

# ── Windows batch launchers (local machine specific) ─────────────────────────
windows/*.bat
windows/_run_*.bat

# ── libimobiledevice binaries (install locally, don't commit) ────────────────
windows/libimobiledevice*/

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# ── macOS ────────────────────────────────────────────────────────────────────
.DS_Store
*.DS_Store

# ── General ──────────────────────────────────────────────────────────────────
*.log
*.tmp
